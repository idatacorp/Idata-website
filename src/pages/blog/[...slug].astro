---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import CtaBanner from '../../components/CtaBanner.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — IData`} description={post.data.description}>
  <Nav />

  <article class="blog-post">
    <div class="bg-grid"></div>
    <div class="container">
      <header class="post-header">
        <a href="/blog" class="back-link">&larr; All Posts</a>
        <div class="post-meta">
          <time datetime={post.data.date}>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          <span class="post-author">by {post.data.author}</span>
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        {post.data.tags.length > 0 && (
          <div class="post-tags">
            {post.data.tags.map((tag) => (
              <span class="badge">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="post-content">
        <Content />
      </div>
    </div>
  </article>

  <CtaBanner />
  <Footer />
</Layout>

<style>
  .blog-post {
    padding: 200px 0 80px;
    position: relative;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.875rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 32px;
    transition: gap var(--transition-fast);
  }

  .back-link:hover {
    gap: 8px;
  }

  .post-header {
    max-width: 720px;
    margin-bottom: 48px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 16px;
  }

  .post-author {
    color: var(--text-secondary);
  }

  .post-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .post-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .post-content {
    max-width: 720px;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 48px;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .post-content :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 36px;
    margin-bottom: 12px;
  }

  .post-content :global(p) {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: 20px;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: 20px;
    padding-left: 24px;
  }

  .post-content :global(li) {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 8px;
  }

  .post-content :global(strong) {
    color: var(--text-primary);
  }

  .post-content :global(em) {
    color: var(--text-primary);
    font-style: italic;
  }

  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .post-content :global(hr) {
    border: none;
    height: 1px;
    background: var(--border-color);
    margin: 40px 0;
  }

  .post-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    background: var(--bg-card);
    padding: 2px 6px;
    border-radius: 4px;
  }
</style>
