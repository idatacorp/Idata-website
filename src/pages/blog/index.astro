---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import PageHeader from '../../components/PageHeader.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Blog — IData" description="AI-focused thought leadership from IData's consulting team.">
  <Nav />
  <PageHeader headline="Insights" subheadline="Thought leadership on AI, data modernization, and enterprise technology." />

  <section class="blog-listing">
    <div class="container">
      <div class="posts">
        {posts.map((post, i) => (
          <a href={`/blog/${post.id}`} class="post-card card animate-on-scroll" style={`transition-delay: ${i * 80}ms`}>
            <div class="post-meta">
              <time datetime={post.data.date}>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              {post.data.tags.length > 0 && (
                <div class="post-tags">
                  {post.data.tags.slice(0, 2).map((tag) => (
                    <span class="badge">{tag}</span>
                  ))}
                </div>
              )}
            </div>
            <h2 class="post-title">{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
            <span class="read-more">Read Article &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .blog-listing {
    padding: 40px 0 120px;
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 24px;
    max-width: 800px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    cursor: pointer;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .post-meta time {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .post-tags {
    display: flex;
    gap: 6px;
  }

  .post-title {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .post-desc {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .read-more {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
  }
</style>
