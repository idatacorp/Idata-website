---
interface Props {
  title: string;
  theme: string;
  href?: string;
}

const { title, theme, href = '/blog' } = Astro.props;
---

<a href={href} class="card blog-card">
  <span class="blog-theme">{theme}</span>
  <h3 class="card-title">{title}</h3>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    cursor: pointer;
  }

  .blog-theme {
    font-size: 0.8rem;
    color: var(--accent);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
