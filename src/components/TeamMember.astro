---
interface Props {
  name: string;
  title: string;
  initials: string;
  photo?: string;
  bio: string[];
}

const { name, title, initials, photo, bio } = Astro.props;
---

<div class="team-member card animate-on-scroll">
  <div class="member-header">
    {photo ? (
      <img src={photo} alt={name} class="avatar-photo" />
    ) : (
      <div class="avatar">
        <span class="avatar-initials">{initials}</span>
      </div>
    )}
    <div>
      <h3 class="member-name">{name}</h3>
      <p class="member-title">{title}</p>
    </div>
  </div>
  <div class="member-bio">
    {bio.map((paragraph) => (
      <p>{paragraph}</p>
    ))}
  </div>
</div>

<style>
  .team-member {
    padding: 40px;
  }

  .member-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
  }

  .avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .avatar-initials {
    font-size: 1.5rem;
    font-weight: 700;
    color: #000;
  }

  .avatar-photo {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 2px solid var(--border-color);
  }

  .member-name {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 4px;
  }

  .member-title {
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 500;
  }

  .member-bio {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .member-bio p {
    font-size: 0.925rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
</style>
