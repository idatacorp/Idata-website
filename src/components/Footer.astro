---
---

<footer class="footer">
  <hr class="section-divider" />
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="IData Home">
        <img src="/green-logo.gif" alt="IData" class="footer-logo-img" />
      </a>
      <p class="footer-tagline">AI & Data Consulting</p>
    </div>

    <div class="footer-contact">
      <a href="mailto:info@idata.net" class="footer-link">info@idata.net</a>
      <a href="https://www.linkedin.com/company/14068550" target="_blank" rel="noopener noreferrer" class="footer-link linkedin-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
    </div>

    <div class="footer-copyright">
      &copy; 2026 IData Corporation. All rights reserved.
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-top: 0;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    padding-top: 48px;
    padding-bottom: 48px;
    text-align: center;
  }

  .footer-logo {
    display: inline-flex;
    margin-bottom: 8px;
  }

  .footer-logo-img {
    height: 120px;
    width: auto;
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .footer-contact {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .footer-link {
    font-size: 0.875rem;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--accent);
  }

  .linkedin-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .footer-copyright {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>
